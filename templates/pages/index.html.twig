{% extends 'base.html.twig' %}

{% block title %}
  Willkommen - Theatergruppe Freispiel
{% endblock %}

{% block body %}
  <div class="row justify-content-center">
    <div class="col-lg-10">
      {# Hero Section #}
      <div class="text-center mb-5 py-5">
        <h1 class="display-3 hero-title mb-4">🎭 Willkommen bei der Theatergruppe Freispiel! 🎭</h1>
        <p class="hero-lead">
          Wir freuen uns, dich auf unserer Webseite begrüßen zu dürfen.<br />
          Erlebe mit uns die Magie des Theaters!
        </p>
      </div>

      {# Welcome Card #}
      <div class="card shadow-lg mb-5">
        <div class="card-body p-4 p-md-5">
          <h2 class="card-title h3 section-title mb-4">Herzlich Willkommen!</h2>
          <p class="card-text fs-5">
            Die Theatergruppe Freispiel heißt dich herzlich willkommen! Wir sind eine leidenschaftliche Gemeinschaft von Theaterbegeisterten aus Dormagen, die es liebt, Geschichten auf die Bühne zu bringen und Emotionen zum Leben zu erwecken.
          </p>
        </div>
      </div>

      {# Recruiting — "Spotlight" stage panel, sharing the print flyer's identity #}
      <section class="recruit mb-5" aria-labelledby="recruit-heading">
        <div class="recruit-spotlight" aria-hidden="true"></div>
        <span class="recruit-badge" aria-hidden="true">mach<br />mit!</span>
        <div class="recruit-inner">
          <p class="recruit-eyebrow">
            Vorhang auf!
          </p>
          <h2 id="recruit-heading" class="recruit-title">
            <span class="recruit-title-top">Wir suchen</span>
            <span class="recruit-title-big">Dich!</span>
          </h2>
          <p class="recruit-lead">
            … um mit uns die Bühne zu bespielen.
          </p>
          <p class="recruit-text">
            Du hast Lust auf ein verrücktes Team, liebst das Unkonventionelle und Kreative und suchst nach neuen Herausforderungen? Dann bist du bei uns genau richtig — komm einfach zu einer Probestunde vorbei, völlig unverbindlich.
          </p>
          <ul class="recruit-pills" aria-hidden="true">
            <li class="recruit-pill recruit-pill-red">unkonventionell</li>
            <li class="recruit-pill recruit-pill-blue">Improvisation</li>
            <li class="recruit-pill recruit-pill-green">neue Herausforderungen</li>
          </ul>
          <div class="recruit-actions">
            <a href="{{ path('app_contact') }}" class="btn btn-primary btn-lg recruit-cta">Mach mit – kontaktiere uns</a>
            <a href="/20260626-freispiel-flyer.html" class="recruit-ghost" target="_blank" rel="noopener">Flyer ansehen</a>
          </div>
        </div>
      </section>

      {# Feature Cards #}
      <div class="row g-4 mb-5">
        <div class="col-md-6">
          <div class="card h-100 shadow">
            <div class="card-body p-4">
              <div class="feature-icon mb-3">
                🌟
              </div>
              <h3 class="card-title h4 text-center mb-3">Unsere Mission</h3>
              <p class="card-text">
                Wir möchten durch die Kraft des Theaters Menschen berühren, unterhalten und zum Nachdenken anregen. Jede Aufführung ist für uns eine neue Reise, die wir gemeinsam mit unserem Publikum erleben.
              </p>
            </div>
          </div>
        </div>
        <div class="col-md-6">
          <div class="card h-100 shadow">
            <div class="card-body p-4">
              <div class="feature-icon mb-3">
                🎬
              </div>
              <h3 class="card-title h4 text-center mb-3">Was uns bewegt</h3>
              <p class="card-text">
                Kreativität, Leidenschaft und Gemeinschaft stehen im Mittelpunkt unserer Arbeit. Wir experimentieren gerne mit verschiedenen Theaterformen und freuen uns über jeden, der unsere Begeisterung teilt.
              </p>
            </div>
          </div>
        </div>
      </div>

      {# Call to Action #}
      <div class="card card-cta shadow-lg">
        <div class="card-body p-4 p-md-5 text-center">
          <h4 class="card-title h3 mb-4">📣 Bleib informiert!</h4>
          <p class="card-text fs-5 mb-4">
            Möchtest du mehr über unsere kommenden Aufführungen erfahren oder hast du Fragen? Wir freuen uns auf deine Nachricht!
          </p>
          <a href="{{ path('app_contact') }}" class="btn btn-primary btn-lg px-5 py-3 fw-bold fs-5">Kontaktiere uns</a>
        </div>
      </div>
    </div>
  </div>
{% endblock %}
